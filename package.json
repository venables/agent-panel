{
  "name": "agent-panel",
  "version": "0.1.0",
  "description": "Launch multiple AI coding agents in parallel terminal splits",
  "keywords": [
    "agents",
    "ai",
    "claude",
    "cli",
    "cmux",
    "code-review",
    "codex",
    "ghostty",
    "multi-agent",
    "opencode",
    "splits",
    "terminal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/venables/agent-panel"
  },
  "bin": {
    "agent-panel": "./dist/index.mjs",
    "panel": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "clean": "git clean -xdf node_modules/.cache dist",
    "cli": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "fix": "pnpm run format && pnpm run lint:fix",
    "format": "oxfmt",
    "format:check": "pnpm run format --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "pnpm run lint --fix --fix-suggestions",
    "lint:fixall": "pnpm run lint:fix --fix-dangerously",
    "nuke": "pnpm run clean && git clean -xdf node_modules",
    "outdated": "pnpm dlx npm-check-updates --interactive --format group",
    "prepublishOnly": "pnpm run build",
    "start": "tsx ./dist/index.mjs",
    "test": "vitest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22"
  }
}
